<?xml version="1.0"?>
<rdf:RDF xmlns="https://purl.org/eore#"
     xml:base="https://purl.org/eore"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:uo="http://purl.obolibrary.org/obo/uo.owl#">

    <owl:Ontology rdf:about="https://purl.org/eore">
        <rdfs:label>Prebiotic Origins of Life Ontology (POLO)</rdfs:label>
        <rdfs:comment>Ontology for experimental prebiotic chemistry. Developed as part of the EORE (Executable Online Resource of Experimental Data) project at Rensselaer Polytechnic Institute.</rdfs:comment>
        <dc:creator>Shweta U. Narkar</dc:creator>
        <dc:description>POLO provides a structured vocabulary for annotating and querying experimental prebiotic chemistry data, covering batch and continuous flowthrough experiment types.</dc:description>
        <owl:imports rdf:resource="http://purl.obolibrary.org/obo/uo/releases/2023-05-25/uo.owl"/>
    </owl:Ontology>


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <!-- https://purl.org/eore#hasMetadata -->
    <owl:ObjectProperty rdf:about="https://purl.org/eore#hasMetadata">
        <rdfs:domain rdf:resource="https://purl.org/eore#Experiment"/>
        <rdfs:range rdf:resource="https://purl.org/eore#PaperMetadata"/>
        <rdfs:label>hasMetadata</rdfs:label>
        <rdfs:comment>Links an experiment to its paper metadata provenance.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- https://purl.org/eore#hasSetup -->
    <owl:ObjectProperty rdf:about="https://purl.org/eore#hasSetup">
        <rdfs:domain rdf:resource="https://purl.org/eore#Experiment"/>
        <rdfs:range rdf:resource="https://purl.org/eore#ExperimentSetup"/>
        <rdfs:label>hasSetup</rdfs:label>
        <rdfs:comment>Links an experiment to its experimental setup.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- https://purl.org/eore#hasExperimentType -->
    <owl:ObjectProperty rdf:about="https://purl.org/eore#hasExperimentType">
        <rdfs:domain rdf:resource="https://purl.org/eore#ExperimentSetup"/>
        <rdfs:range rdf:resource="https://purl.org/eore#ExperimentType"/>
        <rdfs:label>hasExperimentType</rdfs:label>
    </owl:ObjectProperty>

    <!-- https://purl.org/eore#hasConditions -->
    <owl:ObjectProperty rdf:about="https://purl.org/eore#hasConditions">
        <rdfs:label>hasConditions</rdfs:label>
        <rdfs:comment>Links an experiment state to its system conditions.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- https://purl.org/eore#hasPhase -->
    <owl:ObjectProperty rdf:about="https://purl.org/eore#hasPhase">
        <rdfs:label>hasPhase</rdfs:label>
        <rdfs:comment>Links an experiment state to one of its phases (gas, liquid, solid).</rdfs:comment>
    </owl:ObjectProperty>

    <!-- https://purl.org/eore#hasUnit -->
    <owl:ObjectProperty rdf:about="https://purl.org/eore#hasUnit">
        <rdfs:label>hasUnit</rdfs:label>
        <rdfs:comment>Links a measurement to its unit of measurement from the Units Ontology.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- https://purl.org/eore#hasMeasurement -->
    <owl:ObjectProperty rdf:about="https://purl.org/eore#hasMeasurement">
        <rdfs:label>hasMeasurement</rdfs:label>
        <rdfs:comment>Links a phase or condition to its method of measurement.</rdfs:comment>
    </owl:ObjectProperty>


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <!-- Paper Metadata Data Properties -->

    <!-- https://purl.org/eore#paperTitle -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#paperTitle">
        <rdfs:domain rdf:resource="https://purl.org/eore#PaperMetadata"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>paperTitle</rdfs:label>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#paperAuthor -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#paperAuthor">
        <rdfs:domain rdf:resource="https://purl.org/eore#PaperMetadata"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>paperAuthor</rdfs:label>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#paperDoi -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#paperDoi">
        <rdfs:domain rdf:resource="https://purl.org/eore#PaperMetadata"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>paperDoi</rdfs:label>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#paperYear -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#paperYear">
        <rdfs:domain rdf:resource="https://purl.org/eore#PaperMetadata"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>paperYear</rdfs:label>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#paperJournal -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#paperJournal">
        <rdfs:domain rdf:resource="https://purl.org/eore#PaperMetadata"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>paperJournal</rdfs:label>
    </owl:DatatypeProperty>


    <!-- Experiment Setup Data Properties -->

    <!-- https://purl.org/eore#systemType -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#systemType">
        <rdfs:domain rdf:resource="https://purl.org/eore#ExperimentSetup"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>systemType</rdfs:label>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#durationHrs -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#durationHrs">
        <rdfs:domain rdf:resource="https://purl.org/eore#ExperimentSetup"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label>durationHrs</rdfs:label>
        <rdfs:comment>Duration of the experiment in hours.</rdfs:comment>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#replicatesCount -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#replicatesCount">
        <rdfs:domain rdf:resource="https://purl.org/eore#ExperimentSetup"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>replicatesCount</rdfs:label>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#unknownReplicatesCount -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#unknownReplicatesCount">
        <rdfs:domain rdf:resource="https://purl.org/eore#ExperimentSetup"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>unknownReplicatesCount</rdfs:label>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#containerMaterial -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#containerMaterial">
        <rdfs:domain rdf:resource="https://purl.org/eore#LoadingConditions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>containerMaterial</rdfs:label>
    </owl:DatatypeProperty>


    <!-- Conditions Data Properties -->

    <!-- https://purl.org/eore#pressure -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#pressure">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label>pressure</rdfs:label>
        <rdfs:comment>System pressure in bars.</rdfs:comment>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#temperature -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#temperature">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label>temperature</rdfs:label>
        <rdfs:comment>System temperature in Celsius.</rdfs:comment>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#volume -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#volume">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label>volume</rdfs:label>
        <rdfs:comment>System volume in millilitres.</rdfs:comment>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#isRoomTemperature -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#isRoomTemperature">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>isRoomTemperature</rdfs:label>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#isIsobaric -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#isIsobaric">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>isIsobaric</rdfs:label>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#isIsothermal -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#isIsothermal">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>isIsothermal</rdfs:label>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#isIsochoric -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#isIsochoric">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>isIsochoric</rdfs:label>
    </owl:DatatypeProperty>


    <!-- Gas Phase Data Properties -->

    <!-- https://purl.org/eore#gasName -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#gasName">
        <rdfs:domain rdf:resource="https://purl.org/eore#GasPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>gasName</rdfs:label>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#gasConcentration -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#gasConcentration">
        <rdfs:domain rdf:resource="https://purl.org/eore#GasPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label>gasConcentration</rdfs:label>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#ambientAtmosphere -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#ambientAtmosphere">
        <rdfs:domain rdf:resource="https://purl.org/eore#GasPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>ambientAtmosphere</rdfs:label>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#gasIsMeasured -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#gasIsMeasured">
        <rdfs:domain rdf:resource="https://purl.org/eore#GasPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>gasIsMeasured</rdfs:label>
    </owl:DatatypeProperty>


    <!-- Liquid Phase Data Properties -->

    <!-- https://purl.org/eore#solventName -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#solventName">
        <rdfs:domain rdf:resource="https://purl.org/eore#LiquidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>solventName</rdfs:label>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#solventType -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#solventType">
        <rdfs:domain rdf:resource="https://purl.org/eore#LiquidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>solventType</rdfs:label>
        <rdfs:comment>Type of solvent e.g. organic or inorganic.</rdfs:comment>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#soluteName -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#soluteName">
        <rdfs:domain rdf:resource="https://purl.org/eore#LiquidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>soluteName</rdfs:label>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#soluteConcentration -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#soluteConcentration">
        <rdfs:domain rdf:resource="https://purl.org/eore#LiquidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label>soluteConcentration</rdfs:label>
        <rdfs:comment>Solute concentration in mM/L.</rdfs:comment>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#soluteConcentrationUnknown -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#soluteConcentrationUnknown">
        <rdfs:domain rdf:resource="https://purl.org/eore#LiquidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>soluteConcentrationUnknown</rdfs:label>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#isPolymer -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#isPolymer">
        <rdfs:domain rdf:resource="https://purl.org/eore#LiquidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>isPolymer</rdfs:label>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#polymerLength -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#polymerLength">
        <rdfs:domain rdf:resource="https://purl.org/eore#LiquidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label>polymerLength</rdfs:label>
        <rdfs:comment>Maximum or average polymer length observed.</rdfs:comment>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#polymerLengthUnknown -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#polymerLengthUnknown">
        <rdfs:domain rdf:resource="https://purl.org/eore#LiquidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>polymerLengthUnknown</rdfs:label>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#noOfUniqueMonomers -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#noOfUniqueMonomers">
        <rdfs:domain rdf:resource="https://purl.org/eore#LiquidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>noOfUniqueMonomers</rdfs:label>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#monomerName -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#monomerName">
        <rdfs:domain rdf:resource="https://purl.org/eore#LiquidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>monomerName</rdfs:label>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#freqOfMonomer -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#freqOfMonomer">
        <rdfs:domain rdf:resource="https://purl.org/eore#LiquidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>freqOfMonomer</rdfs:label>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#liquidIsMeasured -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#liquidIsMeasured">
        <rdfs:domain rdf:resource="https://purl.org/eore#LiquidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>liquidIsMeasured</rdfs:label>
    </owl:DatatypeProperty>


    <!-- Solid Phase Data Properties -->

    <!-- https://purl.org/eore#solidName -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#solidName">
        <rdfs:domain rdf:resource="https://purl.org/eore#SolidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>solidName</rdfs:label>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#solidMass -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#solidMass">
        <rdfs:domain rdf:resource="https://purl.org/eore#SolidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label>solidMass</rdfs:label>
        <rdfs:comment>Solid mass in milligrams.</rdfs:comment>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#solidType -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#solidType">
        <rdfs:domain rdf:resource="https://purl.org/eore#SolidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>solidType</rdfs:label>
        <rdfs:comment>Type of solid e.g. mineral, amorphous, rock, other.</rdfs:comment>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#solidIsMeasured -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#solidIsMeasured">
        <rdfs:domain rdf:resource="https://purl.org/eore#SolidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>solidIsMeasured</rdfs:label>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#formOfAmorphSolid -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#formOfAmorphSolid">
        <rdfs:domain rdf:resource="https://purl.org/eore#SolidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>formOfAmorphSolid</rdfs:label>
        <rdfs:comment>Form of amorphous solid e.g. chunk or powder.</rdfs:comment>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#maxGrainSize -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#maxGrainSize">
        <rdfs:domain rdf:resource="https://purl.org/eore#SolidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label>maxGrainSize</rdfs:label>
        <rdfs:comment>Maximum grain size in micrometres.</rdfs:comment>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#minGrainSize -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#minGrainSize">
        <rdfs:domain rdf:resource="https://purl.org/eore#SolidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label>minGrainSize</rdfs:label>
        <rdfs:comment>Minimum grain size in micrometres.</rdfs:comment>
    </owl:DatatypeProperty>

    <!-- https://purl.org/eore#particleSizeUnknown -->
    <owl:DatatypeProperty rdf:about="https://purl.org/eore#particleSizeUnknown">
        <rdfs:domain rdf:resource="https://purl.org/eore#SolidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>particleSizeUnknown</rdfs:label>
    </owl:DatatypeProperty>


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <!-- Top level class -->

    <!-- https://purl.org/eore#Experiment -->
    <owl:Class rdf:about="https://purl.org/eore#Experiment">
        <rdfs:label>Experiment</rdfs:label>
        <rdfs:comment>The top-level class representing a prebiotic chemistry experiment reported in a scientific paper.</rdfs:comment>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eore#hasMetadata"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/eore#PaperMetadata"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eore#hasSetup"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/eore#ExperimentSetup"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>


    <!-- Paper Metadata -->

    <!-- https://purl.org/eore#PaperMetadata -->
    <owl:Class rdf:about="https://purl.org/eore#PaperMetadata">
        <rdfs:label>PaperMetadata</rdfs:label>
        <rdfs:comment>Provenance information about the scientific paper in which the experiment was reported.</rdfs:comment>
    </owl:Class>


    <!-- Experiment Setup -->

    <!-- https://purl.org/eore#ExperimentSetup -->
    <owl:Class rdf:about="https://purl.org/eore#ExperimentSetup">
        <rdfs:label>ExperimentSetup</rdfs:label>
        <rdfs:comment>Describes the experimental setup parameters for a given experiment.</rdfs:comment>
    </owl:Class>

    <!-- https://purl.org/eore#ExperimentType -->
    <owl:Class rdf:about="https://purl.org/eore#ExperimentType">
        <rdfs:subClassOf rdf:resource="https://purl.org/eore#ExperimentSetup"/>
        <rdfs:label>ExperimentType</rdfs:label>
        <rdfs:comment>The type of prebiotic chemistry experiment.</rdfs:comment>
    </owl:Class>

    <!-- https://purl.org/eore#Batch -->
    <owl:Class rdf:about="https://purl.org/eore#Batch">
        <rdfs:subClassOf rdf:resource="https://purl.org/eore#ExperimentType"/>
        <rdfs:label>Batch</rdfs:label>
        <rdfs:comment>A batch experiment where a measured amount of chemical compositions interact over a fixed duration with no additions during the process.</rdfs:comment>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eore#hasConditions"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/eore#LoadingConditions"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eore#hasPhase"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/eore#GasPhase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eore#hasPhase"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/eore#LiquidPhase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eore#hasPhase"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/eore#SolidPhase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <!-- https://purl.org/eore#Flowthrough -->
    <owl:Class rdf:about="https://purl.org/eore#Flowthrough">
        <rdfs:subClassOf rdf:resource="https://purl.org/eore#ExperimentType"/>
        <rdfs:label>Flowthrough</rdfs:label>
        <rdfs:comment>A continuous flowthrough experiment.</rdfs:comment>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eore#hasPhase"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/eore#GasPhase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eore#hasPhase"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/eore#LiquidPhase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eore#hasPhase"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/eore#SolidPhase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>


    <!-- Batch substates -->

    <!-- https://purl.org/eore#InitialState -->
    <owl:Class rdf:about="https://purl.org/eore#InitialState">
        <rdfs:subClassOf rdf:resource="https://purl.org/eore#Batch"/>
        <rdfs:label>InitialState</rdfs:label>
        <rdfs:comment>The initial state of a batch experiment before conditions are applied.</rdfs:comment>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eore#hasConditions"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/eore#InitialSystemConditions"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eore#hasPhase"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/eore#GasPhase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eore#hasPhase"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/eore#LiquidPhase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eore#hasPhase"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/eore#SolidPhase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <!-- https://purl.org/eore#FinalState -->
    <owl:Class rdf:about="https://purl.org/eore#FinalState">
        <rdfs:subClassOf rdf:resource="https://purl.org/eore#Batch"/>
        <rdfs:label>FinalState</rdfs:label>
        <rdfs:comment>The final state of a batch experiment after conditions have been applied.</rdfs:comment>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eore#hasConditions"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/eore#FinalSystemConditions"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eore#hasPhase"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/eore#GasPhase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eore#hasPhase"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/eore#LiquidPhase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eore#hasPhase"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/eore#SolidPhase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>


    <!-- Flowthrough substates -->

    <!-- https://purl.org/eore#Stationary -->
    <owl:Class rdf:about="https://purl.org/eore#Stationary">
        <rdfs:subClassOf rdf:resource="https://purl.org/eore#Flowthrough"/>
        <rdfs:label>Stationary</rdfs:label>
        <rdfs:comment>The stationary component of a flowthrough experiment.</rdfs:comment>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eore#hasPhase"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/eore#LiquidPhase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eore#hasPhase"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/eore#SolidPhase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <!-- https://purl.org/eore#Continuous -->
    <owl:Class rdf:about="https://purl.org/eore#Continuous">
        <rdfs:subClassOf rdf:resource="https://purl.org/eore#Flowthrough"/>
        <rdfs:label>Continuous</rdfs:label>
        <rdfs:comment>The continuous component of a flowthrough experiment where fluid passes through the stationary stage.</rdfs:comment>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eore#hasPhase"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/eore#GasPhase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eore#hasPhase"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/eore#LiquidPhase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <!-- https://purl.org/eore#Analysis -->
    <owl:Class rdf:about="https://purl.org/eore#Analysis">
        <rdfs:subClassOf rdf:resource="https://purl.org/eore#Flowthrough"/>
        <rdfs:label>Analysis</rdfs:label>
        <rdfs:comment>The analysis component of a flowthrough experiment.</rdfs:comment>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eore#hasPhase"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/eore#GasPhase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eore#hasPhase"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/eore#LiquidPhase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eore#hasPhase"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/eore#SolidPhase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>


    <!-- Conditions -->

    <!-- https://purl.org/eore#Conditions -->
    <owl:Class rdf:about="https://purl.org/eore#Conditions">
        <rdfs:label>Conditions</rdfs:label>
        <rdfs:comment>System conditions for an experiment at a given state.</rdfs:comment>
    </owl:Class>

    <!-- https://purl.org/eore#LoadingConditions -->
    <owl:Class rdf:about="https://purl.org/eore#LoadingConditions">
        <rdfs:subClassOf rdf:resource="https://purl.org/eore#Conditions"/>
        <rdfs:label>LoadingConditions</rdfs:label>
        <rdfs:comment>Conditions at the loading stage of a batch experiment.</rdfs:comment>
    </owl:Class>

    <!-- https://purl.org/eore#InitialSystemConditions -->
    <owl:Class rdf:about="https://purl.org/eore#InitialSystemConditions">
        <rdfs:subClassOf rdf:resource="https://purl.org/eore#Conditions"/>
        <rdfs:label>InitialSystemConditions</rdfs:label>
        <rdfs:comment>System conditions recorded at the initial state of a batch experiment.</rdfs:comment>
    </owl:Class>

    <!-- https://purl.org/eore#FinalSystemConditions -->
    <owl:Class rdf:about="https://purl.org/eore#FinalSystemConditions">
        <rdfs:subClassOf rdf:resource="https://purl.org/eore#Conditions"/>
        <rdfs:label>FinalSystemConditions</rdfs:label>
        <rdfs:comment>System conditions recorded at the final state of a batch experiment.</rdfs:comment>
    </owl:Class>


    <!-- Phases -->

    <!-- https://purl.org/eore#Phases -->
    <owl:Class rdf:about="https://purl.org/eore#Phases">
        <rdfs:label>Phases</rdfs:label>
        <rdfs:comment>The phases of matter present in an experiment.</rdfs:comment>
    </owl:Class>

    <!-- https://purl.org/eore#GasPhase -->
    <owl:Class rdf:about="https://purl.org/eore#GasPhase">
        <rdfs:subClassOf rdf:resource="https://purl.org/eore#Phases"/>
        <rdfs:label>GasPhase</rdfs:label>
        <rdfs:comment>The gas phase component of an experiment.</rdfs:comment>
    </owl:Class>

    <!-- https://purl.org/eore#LiquidPhase -->
    <owl:Class rdf:about="https://purl.org/eore#LiquidPhase">
        <rdfs:subClassOf rdf:resource="https://purl.org/eore#Phases"/>
        <rdfs:label>LiquidPhase</rdfs:label>
        <rdfs:comment>The liquid phase component of an experiment.</rdfs:comment>
    </owl:Class>

    <!-- https://purl.org/eore#SolidPhase -->
    <owl:Class rdf:about="https://purl.org/eore#SolidPhase">
        <rdfs:subClassOf rdf:resource="https://purl.org/eore#Phases"/>
        <rdfs:label>SolidPhase</rdfs:label>
        <rdfs:comment>The solid phase component of an experiment.</rdfs:comment>
    </owl:Class>

</rdf:RDF>
