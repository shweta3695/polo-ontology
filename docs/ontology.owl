<?xml version="1.0"?>
<rdf:RDF xmlns="https://purl.org/polo#"
     xml:base="https://purl.org/polo"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="https://purl.org/polo">
        <owl:imports rdf:resource="http://purl.obolibrary.org/obo/uo/releases/2023-05-25/uo.owl"/>
        <dc:creator>Shweta U. Narkar</dc:creator>
        <dc:description>POLO provides a structured vocabulary for annotating and querying experimental prebiotic chemistry data, covering batch and continuous flowthrough experiment types.</dc:description>
        <rdfs:comment>Ontology for experimental prebiotic chemistry. Developed as part of the EORE (Executable Online Resource of Experimental Data) project at Rensselaer Polytechnic Institute.</rdfs:comment>
        <rdfs:label>Prebiotic Origins of Life Ontology (POLO)</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/elements/1.1/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://purl.org/polo#hasConditions -->


    <owl:ObjectProperty rdf:about="https://purl.org/polo#hasConditions">
        <rdfs:comment>Links an experiment state to its system conditions.</rdfs:comment>
        <rdfs:label>hasConditions</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/polo#hasExperimentType -->


    <owl:ObjectProperty rdf:about="https://purl.org/polo#hasExperimentType">
        <rdfs:domain rdf:resource="https://purl.org/polo#ExperimentSetup"/>
        <rdfs:range rdf:resource="https://purl.org/polo#ExperimentType"/>
        <rdfs:label>hasExperimentType</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/polo#hasMeasurement -->


    <owl:ObjectProperty rdf:about="https://purl.org/polo#hasMeasurement">
        <rdfs:comment>Links a phase or condition to its method of measurement.</rdfs:comment>
        <rdfs:label>hasMeasurement</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/polo#hasMetadata -->


    <owl:ObjectProperty rdf:about="https://purl.org/polo#hasMetadata">
        <rdfs:domain rdf:resource="https://purl.org/polo#Experiment"/>
        <rdfs:range rdf:resource="https://purl.org/polo#PaperMetadata"/>
        <rdfs:comment>Links an experiment to its paper metadata provenance.</rdfs:comment>
        <rdfs:label>hasMetadata</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/polo#hasPhase -->


    <owl:ObjectProperty rdf:about="https://purl.org/polo#hasPhase">
        <rdfs:comment>Links an experiment state to one of its phases (gas, liquid, solid).</rdfs:comment>
        <rdfs:label>hasPhase</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/polo#hasSetup -->


    <owl:ObjectProperty rdf:about="https://purl.org/polo#hasSetup">
        <rdfs:domain rdf:resource="https://purl.org/polo#Experiment"/>
        <rdfs:range rdf:resource="https://purl.org/polo#ExperimentSetup"/>
        <rdfs:comment>Links an experiment to its experimental setup.</rdfs:comment>
        <rdfs:label>hasSetup</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/polo#hasState -->


    <owl:ObjectProperty rdf:about="https://purl.org/polo#hasState">
        <rdfs:domain rdf:resource="https://purl.org/polo#Batch"/>
        <rdfs:range rdf:resource="https://purl.org/polo#ExperimentState"/>
        <rdfs:comment>Links a batch experiment to its initial or final state.</rdfs:comment>
        <rdfs:label>hasState</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/polo#hasUnit -->


    <owl:ObjectProperty rdf:about="https://purl.org/polo#hasUnit">
        <rdfs:comment>Links a measurement to its unit of measurement from the Units Ontology.</rdfs:comment>
        <rdfs:label>hasUnit</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://purl.org/polo#ambientAtmosphere -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#ambientAtmosphere">
        <rdfs:domain rdf:resource="https://purl.org/polo#GasPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>ambientAtmosphere</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#containerMaterial -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#containerMaterial">
        <rdfs:domain rdf:resource="https://purl.org/polo#LoadingConditions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>containerMaterial</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#durationHrs -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#durationHrs">
        <rdfs:domain rdf:resource="https://purl.org/polo#ExperimentSetup"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Duration of the experiment in hours.</rdfs:comment>
        <rdfs:label>durationHrs</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#formOfAmorphSolid -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#formOfAmorphSolid">
        <rdfs:domain rdf:resource="https://purl.org/polo#SolidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Form of amorphous solid e.g. chunk or powder.</rdfs:comment>
        <rdfs:label>formOfAmorphSolid</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#freqOfMonomer -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#freqOfMonomer">
        <rdfs:domain rdf:resource="https://purl.org/polo#LiquidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>freqOfMonomer</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#gasConcentration -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#gasConcentration">
        <rdfs:domain rdf:resource="https://purl.org/polo#GasPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label>gasConcentration</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#gasIsMeasured -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#gasIsMeasured">
        <rdfs:domain rdf:resource="https://purl.org/polo#GasPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>gasIsMeasured</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#gasName -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#gasName">
        <rdfs:domain rdf:resource="https://purl.org/polo#GasPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>gasName</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#isIsobaric -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#isIsobaric">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>isIsobaric</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#isIsochoric -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#isIsochoric">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>isIsochoric</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#isIsothermal -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#isIsothermal">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>isIsothermal</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#isPolymer -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#isPolymer">
        <rdfs:domain rdf:resource="https://purl.org/polo#LiquidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>isPolymer</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#isRoomTemperature -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#isRoomTemperature">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>isRoomTemperature</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#liquidIsMeasured -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#liquidIsMeasured">
        <rdfs:domain rdf:resource="https://purl.org/polo#LiquidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>liquidIsMeasured</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#maxGrainSize -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#maxGrainSize">
        <rdfs:domain rdf:resource="https://purl.org/polo#SolidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Maximum grain size in micrometres.</rdfs:comment>
        <rdfs:label>maxGrainSize</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#minGrainSize -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#minGrainSize">
        <rdfs:domain rdf:resource="https://purl.org/polo#SolidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Minimum grain size in micrometres.</rdfs:comment>
        <rdfs:label>minGrainSize</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#monomerName -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#monomerName">
        <rdfs:domain rdf:resource="https://purl.org/polo#LiquidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>monomerName</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#noOfUniqueMonomers -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#noOfUniqueMonomers">
        <rdfs:domain rdf:resource="https://purl.org/polo#LiquidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>noOfUniqueMonomers</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#paperAuthor -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#paperAuthor">
        <rdfs:domain rdf:resource="https://purl.org/polo#PaperMetadata"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>paperAuthor</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#paperDoi -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#paperDoi">
        <rdfs:domain rdf:resource="https://purl.org/polo#PaperMetadata"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>paperDoi</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#paperJournal -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#paperJournal">
        <rdfs:domain rdf:resource="https://purl.org/polo#PaperMetadata"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>paperJournal</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#paperTitle -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#paperTitle">
        <rdfs:domain rdf:resource="https://purl.org/polo#PaperMetadata"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>paperTitle</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#paperYear -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#paperYear">
        <rdfs:domain rdf:resource="https://purl.org/polo#PaperMetadata"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>paperYear</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#particleSizeUnknown -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#particleSizeUnknown">
        <rdfs:domain rdf:resource="https://purl.org/polo#SolidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>particleSizeUnknown</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#polymerLength -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#polymerLength">
        <rdfs:domain rdf:resource="https://purl.org/polo#LiquidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Maximum or average polymer length observed.</rdfs:comment>
        <rdfs:label>polymerLength</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#polymerLengthUnknown -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#polymerLengthUnknown">
        <rdfs:domain rdf:resource="https://purl.org/polo#LiquidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>polymerLengthUnknown</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#pressure -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#pressure">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>System pressure in bars.</rdfs:comment>
        <rdfs:label>pressure</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#replicatesCount -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#replicatesCount">
        <rdfs:domain rdf:resource="https://purl.org/polo#ExperimentSetup"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>replicatesCount</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#solidIsMeasured -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#solidIsMeasured">
        <rdfs:domain rdf:resource="https://purl.org/polo#SolidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>solidIsMeasured</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#solidMass -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#solidMass">
        <rdfs:domain rdf:resource="https://purl.org/polo#SolidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Solid mass in milligrams.</rdfs:comment>
        <rdfs:label>solidMass</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#solidName -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#solidName">
        <rdfs:domain rdf:resource="https://purl.org/polo#SolidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>solidName</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#solidType -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#solidType">
        <rdfs:domain rdf:resource="https://purl.org/polo#SolidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Type of solid e.g. mineral, amorphous, rock, other.</rdfs:comment>
        <rdfs:label>solidType</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#soluteConcentration -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#soluteConcentration">
        <rdfs:domain rdf:resource="https://purl.org/polo#LiquidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Solute concentration in mM/L.</rdfs:comment>
        <rdfs:label>soluteConcentration</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#soluteConcentrationUnknown -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#soluteConcentrationUnknown">
        <rdfs:domain rdf:resource="https://purl.org/polo#LiquidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>soluteConcentrationUnknown</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#soluteName -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#soluteName">
        <rdfs:domain rdf:resource="https://purl.org/polo#LiquidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>soluteName</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#solventName -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#solventName">
        <rdfs:domain rdf:resource="https://purl.org/polo#LiquidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>solventName</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#solventType -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#solventType">
        <rdfs:domain rdf:resource="https://purl.org/polo#LiquidPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Type of solvent e.g. organic or inorganic.</rdfs:comment>
        <rdfs:label>solventType</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#systemType -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#systemType">
        <rdfs:domain rdf:resource="https://purl.org/polo#ExperimentSetup"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>systemType</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#temperature -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#temperature">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>System temperature in Celsius.</rdfs:comment>
        <rdfs:label>temperature</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#unknownReplicatesCount -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#unknownReplicatesCount">
        <rdfs:domain rdf:resource="https://purl.org/polo#ExperimentSetup"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>unknownReplicatesCount</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/polo#volume -->


    <owl:DatatypeProperty rdf:about="https://purl.org/polo#volume">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>System volume in millilitres.</rdfs:comment>
        <rdfs:label>volume</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://purl.org/polo#Analysis -->


    <owl:Class rdf:about="https://purl.org/polo#Analysis">
        <rdfs:subClassOf rdf:resource="https://purl.org/polo#Flowthrough"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/polo#hasPhase"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/polo#GasPhase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/polo#hasPhase"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/polo#LiquidPhase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/polo#hasPhase"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/polo#SolidPhase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>The analysis component of a flowthrough experiment.</rdfs:comment>
        <rdfs:label>Analysis</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/polo#Batch -->


    <owl:Class rdf:about="https://purl.org/polo#Batch">
        <rdfs:subClassOf rdf:resource="https://purl.org/polo#ExperimentType"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/polo#hasConditions"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/polo#LoadingConditions"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/polo#hasState"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/polo#FinalState"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/polo#hasState"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/polo#InitialState"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A batch experiment where a measured amount of chemical compositions interact over a fixed duration with no additions during the process.</rdfs:comment>
        <rdfs:label>Batch</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/polo#Conditions -->


    <owl:Class rdf:about="https://purl.org/polo#Conditions">
        <rdfs:comment>System conditions for an experiment at a given state.</rdfs:comment>
        <rdfs:label>Conditions</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/polo#Continuous -->


    <owl:Class rdf:about="https://purl.org/polo#Continuous">
        <rdfs:subClassOf rdf:resource="https://purl.org/polo#Flowthrough"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/polo#hasPhase"/>
