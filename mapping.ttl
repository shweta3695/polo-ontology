        rr:objectMap [
            rml:reference "is_isobaric_batch";
            rr:datatype xsd:boolean
        ]
    ];

    rr:predicateObjectMap [
        rr:predicate ex:isRoomTemperature;
        rr:objectMap [
            rml:reference "room_temperature_initial";
            rr:datatype xsd:boolean
        ]
    ];

    rr:predicateObjectMap [
        rr:predicate ex:temperature;
        rr:objectMap [
            rml:reference "temperature_initial";
            rr:datatype xsd:decimal
        ]
    ];

    rr:predicateObjectMap [
        rr:predicate ex:isIsothermal;
        rr:objectMap [
            rml:reference "is_isothermal_batch";
            rr:datatype xsd:boolean
        ]
    ];

    rr:predicateObjectMap [
        rr:predicate ex:volume;
        rr:objectMap [
            rml:reference "total_system_volume_initial";
            rr:datatype xsd:decimal
        ]
    ];

    rr:predicateObjectMap [
        rr:predicate ex:isIsochoric;
        rr:objectMap [
            rml:reference "is_isochoric_batch";
            rr:datatype xsd:boolean
        ]
    ].


