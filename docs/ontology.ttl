###  https://purl.org/polo#noOfUniqueMonomers
:noOfUniqueMonomers rdf:type owl:DatatypeProperty ;
                    rdfs:domain :LiquidPhase ;
                    rdfs:range xsd:integer ;
                    rdfs:label "noOfUniqueMonomers" .


