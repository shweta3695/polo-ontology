:soluteName rdf:type owl:DatatypeProperty ;
            rdfs:domain :LiquidPhase ;
            rdfs:range xsd:string ;
            rdfs:label "soluteName" .


###  https://purl.org/polo#solventName
:solventName rdf:type owl:DatatypeProperty ;
