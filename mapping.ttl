        rml:referenceFormulation ql:CSV
    ];
    rr:subjectMap [
        rr:template "https://purl.org/eore/initialconditions/{id}";
        rr:class ex:InitialSystemConditions
    ];

    rr:predicateObjectMap [
        rr:predicate ex:pressure;
        rr:objectMap [
            rml:reference "total_system_pressure_initial";
            rr:datatype xsd:decimal
        ]
    ];

    rr:predicateObjectMap [
