@prefix : <https://purl.org/eore/mapping#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ex: <https://purl.org/eore#> .

# =============================================================================
# LOGICAL SOURCE - shared CSV source for all TriplesMaps
# =============================================================================

# =============================================================================
# 1. EXPERIMENT TRIPLES MAP
# Top level class - one experiment per row
# =============================================================================

:ExperimentTriplesMap a rr:TriplesMap;
    rml:logicalSource [
        rml:source "experiments.csv";
        rml:referenceFormulation ql:CSV
    ];
    rr:subjectMap [
        rr:template "https://purl.org/eore/experiment/{id}";
        rr:class ex:Experiment
    ];

    # Link to PaperMetadata
    rr:predicateObjectMap [
        rr:predicate ex:hasMetadata;
        rr:objectMap [
            rr:template "https://purl.org/eore/paper/{paper_doi}"
        ]
    ];

    # Link to ExperimentSetup
    rr:predicateObjectMap [
        rr:predicate ex:hasSetup;
        rr:objectMap [
            rr:template "https://purl.org/eore/setup/{id}"
        ]
    ].


# =============================================================================
# 2. PAPER METADATA TRIPLES MAP
# =============================================================================

:PaperMetadataTriplesMap a rr:TriplesMap;
    rml:logicalSource [
        rml:source "experiments.csv";
        rml:referenceFormulation ql:CSV
    ];
    rr:subjectMap [
        rr:template "https://purl.org/eore/paper/{paper_doi}";
        rr:class ex:PaperMetadata
    ];

    rr:predicateObjectMap [
        rr:predicate ex:paperTitle;
        rr:objectMap [
            rml:reference "paper_title";
            rr:datatype xsd:string
        ]
    ];

    rr:predicateObjectMap [
        rr:predicate ex:paperAuthor;
        rr:objectMap [
            rml:reference "paper_author";
            rr:datatype xsd:string
        ]
    ];

    rr:predicateObjectMap [
        rr:predicate ex:paperDoi;
        rr:objectMap [
            rml:reference "paper_doi";
            rr:datatype xsd:string
        ]
    ];

    rr:predicateObjectMap [
        rr:predicate ex:paperYear;
        rr:objectMap [
            rml:reference "paper_year";
            rr:datatype xsd:integer
        ]
    ];

    rr:predicateObjectMap [
        rr:predicate ex:paperJournal;
        rr:objectMap [
            rml:reference "paper_journal";
            rr:datatype xsd:string
        ]
    ].


# =============================================================================
# 3. EXPERIMENT SETUP TRIPLES MAP
# =============================================================================

:ExperimentSetupTriplesMap a rr:TriplesMap;
    rml:logicalSource [
        rml:source "experiments.csv";
        rml:referenceFormulation ql:CSV
    ];
    rr:subjectMap [
        rr:template "https://purl.org/eore/setup/{id}";
        rr:class ex:ExperimentSetup
    ];

    rr:predicateObjectMap [
        rr:predicate ex:systemType;
        rr:objectMap [
            rml:reference "system_type";
            rr:datatype xsd:string
        ]
    ];

    rr:predicateObjectMap [
        rr:predicate ex:durationHrs;
        rr:objectMap [
            rml:reference "duration_hr";
            rr:datatype xsd:decimal
        ]
    ];

    rr:predicateObjectMap [
        rr:predicate ex:replicatesCount;
        rr:objectMap [
            rml:reference "replicates_count";
            rr:datatype xsd:integer
        ]
    ];

    rr:predicateObjectMap [
        rr:predicate ex:unknownReplicatesCount;
        rr:objectMap [
            rml:reference "unknown_replicates_count";
            rr:datatype xsd:boolean
        ]
    ];

    # Link to ExperimentType (Batch or Flowthrough)
    rr:predicateObjectMap [
        rr:predicate ex:hasExperimentType;
        rr:objectMap [
            rr:template "https://purl.org/eore/experimenttype/{id}"
        ]
    ].


# =============================================================================
# 4. BATCH TRIPLES MAP
# Only for rows where experiment_type = batch
# =============================================================================

:BatchTriplesMap a rr:TriplesMap;
    rml:logicalSource [
        rml:source "experiments.csv";
        rml:referenceFormulation ql:CSV
    ];
    rr:subjectMap [
        rr:template "https://purl.org/eore/experimenttype/{id}";
        rr:class ex:Batch
    ];

    # Link to LoadingConditions
    rr:predicateObjectMap [
        rr:predicate ex:hasConditions;
        rr:objectMap [
            rr:template "https://purl.org/eore/loadingconditions/{id}"
        ]
    ];

    # Link to InitialState
    rr:predicateObjectMap [
        rr:predicate ex:hasPhase;
        rr:objectMap [
            rr:template "https://purl.org/eore/initialstate/{id}"
        ]
    ];

    # Link to FinalState
    rr:predicateObjectMap [
        rr:predicate ex:hasPhase;
        rr:objectMap [
            rr:template "https://purl.org/eore/finalstate/{id}"
        ]
    ].


# =============================================================================
# 5. LOADING CONDITIONS TRIPLES MAP
# =============================================================================

:LoadingConditionsTriplesMap a rr:TriplesMap;
    rml:logicalSource [
        rml:source "experiments.csv";
        rml:referenceFormulation ql:CSV
    ];
    rr:subjectMap [
        rr:template "https://purl.org/eore/loadingconditions/{id}";
        rr:class ex:LoadingConditions
    ];

    rr:predicateObjectMap [
        rr:predicate ex:pressure;
        rr:objectMap [
            rml:reference "loading_pressure_batch";
            rr:datatype xsd:decimal
        ]
    ];

    rr:predicateObjectMap [
        rr:predicate ex:isRoomTemperature;
        rr:objectMap [
            rml:reference "loading_room_temperature_batch";
            rr:datatype xsd:boolean
        ]
    ];

    rr:predicateObjectMap [
        rr:predicate ex:volume;
        rr:objectMap [
            rml:reference "loading_volume_batch";
            rr:datatype xsd:decimal
        ]
    ];

    rr:predicateObjectMap [
        rr:predicate ex:containerMaterial;
        rr:objectMap [
            rml:reference "sample_containing_material_batch";
            rr:datatype xsd:string
        ]
    ].


